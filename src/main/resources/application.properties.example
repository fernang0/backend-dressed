# =============================================
# APP
# =============================================
spring.application.name=backend-dressed

# =============================================
# SERVER
# =============================================
server.port=8081

# =============================================
# BASE DE DATOS - NEON POSTGRES
# =============================================
spring.datasource.url=jdbc:postgresql://ep-odd-mouse-anaer86n-pooler.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require
spring.datasource.username=neondb_owner
spring.datasource.password=${DB_PASSWORD:}

# =============================================
# MAIL / SMTP
# =============================================
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=${MAIL_USERNAME:}
spring.mail.password=${MAIL_PASSWORD:}
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true

# =============================================
# JPA / HIBERNATE
# =============================================
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect

# =============================================
# JWT
# =============================================
app.jwt.secret=${JWT_SECRET:}
app.jwt.expiration-ms=86400000

# =============================================
# COOKIES JWT
# =============================================
jwt.cookie.name=access_token
jwt.cookie.max-age=86400

# =============================================
# FRONTEND / CORS
# =============================================
app.frontend.url=${FRONTEND_URL:http://localhost:5173}
cors.allowed.origins=http://localhost:5173

# =============================================
# SCRAPER
# =============================================
app.scraper.base-url=http://localhost:3000
app.scraper.api-key=${SCRAPER_API_KEY:}

# =============================================
# LOGGING
# =============================================
logging.level.org.springframework.security=INFO
logging.level.org.hibernate.SQL=ERROR